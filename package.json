{
  "name": "pi-fenced",
  "description": "PI coding agent extension and launcher for running PI in a Fence sandbox and configuring Fence policy out of process.",
  "keywords": [
    "pi-package"
  ],
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "clean": "echo 'nothing to clean'",
    "build": "echo 'nothing to build'",
    "check": "echo 'nothing to check'",
    "test": "node --test tests/**/*.test.ts"
  },
  "bin": {
    "pi-fenced": "./bin/pi-fenced.js"
  },
  "files": [
    "README.md",
    "bin/",
    "index.ts",
    "configure-fence.ts",
    "launcher/",
    "apply/",
    "prompts/"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
